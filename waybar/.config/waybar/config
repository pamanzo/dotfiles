{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 15,
    "modules-left": ["hyprland/workspaces", "hyprland/mode"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["network", "cpu", "memory", "pulseaudio", "battery", "clock", "tray"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": "ΎΗΤ",
            "default": "ΎΕΝ"
        }
    },

    "battery": {
        "bat": "BAT0",
        "adapter": "AC",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    },

    "network": {
        "format-wifi": "ΎΘτ {essid}",
        "format-ethernet": "≤░ΙΑ {ifname}",
        "format-disconnected": "≤░Ψς Offline"
    },
    
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "≤░ζθ Muted",
        "on-click": "pavucontrol",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        }
    },

    "clock": {
        "format": "ΎΑΩ {:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "ΎΒ│ {:%d-%m-%Y}"
    },

    "cpu": { 
        "format": "ΎΤ╝ {usage}%" 
    },

    "memory": { 
        "format": "≤░Ξδ {percentage}%" 
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}
